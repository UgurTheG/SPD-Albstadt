# Instagram Graph User ID of the authenticated Business/Creator account
INSTAGRAM_USER_ID=

# Meta Graph API access token for the same account
INSTAGRAM_ACCESS_TOKEN=

# GitHub OAuth App — create at https://github.com/settings/developers
# Callback URLs: https://<your-domain>/api/auth/callback and http://localhost:5173/api/auth/callback
VITE_GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
OAUTH_REDIRECT_URI=

# Dedicated HMAC signing key for OAuth CSRF state (recommended).
# If not set, GITHUB_CLIENT_SECRET is used as a fallback.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
STATE_SIGNING_SECRET=

# Comma-separated GitHub usernames allowed to log in (optional, defence-in-depth).
# Example: ALLOWED_GITHUB_LOGINS=UgurTheG,OtherUser
ALLOWED_GITHUB_LOGINS=
