# Instagram Graph User ID of the authenticated Business/Creator account
INSTAGRAM_USER_ID=

# Meta Graph API access token for the same account
INSTAGRAM_ACCESS_TOKEN=

# GitHub OAuth App — create at https://github.com/settings/developers
# Callback URL: https://<your-domain>/api/auth/callback  (and http://localhost:5173/api/auth/callback for dev)
VITE_GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=


