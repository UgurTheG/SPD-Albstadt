# Instagram Graph User ID of the authenticated Business/Creator account
INSTAGRAM_USER_ID=

# Meta Graph API access token for the same account
INSTAGRAM_ACCESS_TOKEN=

# GitHub App — create at https://github.com/settings/apps
# Callback URLs: https://<your-domain>/api/auth/callback and http://localhost:5173/api/auth/callback
# Required permissions: Repository > Contents (read & write), Metadata (read-only)
VITE_GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=


