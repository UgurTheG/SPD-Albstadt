# ─── SPA fallback for Apache (Hostinger) ────────────────────────────────────
# Rewrite all non-file requests to index.html so React Router handles routing.
# On Vercel this file is ignored — vercel.json handles rewrites instead.

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Admin is only available on Vercel — redirect to the Vercel admin
  RewriteRule ^admin(/.*)?$ https://spd-albstadt.vercel.app/admin$1 [R=302,L]

  # If the request is for an existing file or directory, serve it directly
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d

  # Don't rewrite requests for known static asset extensions
  RewriteCond %{REQUEST_URI} !\.(js|css|png|jpg|jpeg|webp|svg|ico|gif|pdf|woff2?|ttf|eot|map|json|txt|xml)$ [NC]

  # Rewrite everything else to index.html
  RewriteRule ^ index.html [L]
</IfModule>

# ─── Security Headers ─────────────────────────────────────────────────────────
<IfModule mod_headers.c>
  Header set X-Frame-Options "SAMEORIGIN"
  Header set X-Content-Type-Options "nosniff"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set Permissions-Policy "camera=(), microphone=(), geolocation=()"
  Header set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://static.elfsight.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; connect-src 'self' https:; font-src 'self'; frame-src https://static.elfsight.com;"
</IfModule>

# ─── Caching ─────────────────────────────────────────────────────────────────

# Long-term cache for hashed build assets (immutable)
<IfModule mod_headers.c>
  <FilesMatch "\.[a-f0-9]{8,}\.(js|css|woff2?)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>

# No cache for JSON data files (keep content fresh)
<IfModule mod_headers.c>
  <FilesMatch "\.json$">
    Header set Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
    Header set Pragma "no-cache"
  </FilesMatch>
</IfModule>

# ─── CORS for ICS proxy (when frontend calls Vercel API cross-origin) ────────
# Not strictly needed on the static host, but keeps headers consistent.

# ─── Compression ──────────────────────────────────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml
</IfModule>

