{
  "rewrites": [
    {
      "source": "/admin",
      "destination": "/index.html"
    },
    {
      "source": "/admin/",
      "destination": "/index.html"
    },
    {
      "source": "/((?!api|data|images|documents|icons|favicon|manifest\\.json|robots\\.txt|sitemap\\.xml|.*\\.webp|.*\\.svg|.*\\.ico|.*\\.pdf).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/admin(/.*)?",
      "headers": [
        {"key": "Cache-Control", "value": "no-store, no-cache, must-revalidate, max-age=0"},
        {"key": "Pragma", "value": "no-cache"},
        {"key": "Expires", "value": "0"}
      ]
    },
    {
      "source": "/data/(.*)",
      "headers": [
        {"key": "Cache-Control", "value": "no-store, no-cache, must-revalidate, max-age=0"}
      ]
    }
  ]
}

